---
import '../styles/global.css';
import SettingsModal from '../components/SettingsModal.tsx';
import TtsSectionManager from '../components/TtsSectionManager.tsx';
import Sidebar from '../components/Sidebar.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import PlayAllManager from '../components/PlayAllManager.tsx';
import TtsControlsBar from '../components/TtsControlsBar.tsx';
import AnnotationThread from '../components/AnnotationThread.tsx';

import ContentStatusBanner from '../components/ContentStatusBanner.tsx';

import TokenModal from '../components/TokenModal.tsx';
import CommentDraft from '../components/CommentDraft.tsx';
import TableOfContents from '../components/TableOfContents.tsx';
import SearchModal from '../components/SearchModal.tsx';

interface Props {
  title?: string;
  description?: string;
  currentPath?: string;
}

const { title = 'Foundry', description = 'Documentation platform for human-AI collaborative workflows', currentPath = '/' } = Astro.props;
const pageTitle = title === 'Foundry' ? title : `${title} — Foundry`;
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />
  <title>{pageTitle}</title>
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="apple-touch-icon" href="/logo.svg" />
  
  <!-- Open Graph meta tags -->
  <meta property="og:title" content={pageTitle} />
  <meta property="og:description" content={description} />
  <meta property="og:type" content="website" />
  <meta property="og:image" content="/og-image.png" />
  <meta name="twitter:card" content="summary" />
  <meta name="twitter:title" content={pageTitle} />
  <meta name="twitter:description" content={description} />

  {/* Prevent flash of wrong theme */}
  <script is:inline>
    (function() {
      const stored = localStorage.getItem('foundry-theme');
      if (stored) {
        document.documentElement.setAttribute('data-theme', stored);
      } else if (window.matchMedia('(prefers-color-scheme: dark)').matches) {
        document.documentElement.setAttribute('data-theme', 'dark');
      }
    })();
  </script>
  {/* Restore thread panel width before first paint to avoid flash */}
  <script is:inline>
    (function() {
      var stored = localStorage.getItem('foundry-thread-panel-width');
      if (stored) {
        var n = parseFloat(stored);
        var maxPx = window.innerWidth * 0.5;
        if (!isNaN(n) && n >= 200 && n <= maxPx) {
          document.documentElement.style.setProperty('--thread-panel-width', n + 'px');
        }
      }
    })();
  </script>
  <script is:inline>
    (function() {
      if (localStorage.getItem('foundry-tts-enabled') === 'false') {
        document.body.classList.add('tts-disabled');
      }
    })();
  </script>
</head>
<body>
  <header class="header">
    <a href="/" class="header-title" style="text-decoration: none; display: flex; align-items: center; gap: 8px;">
      <img src="/logo.svg" alt="Foundry" width="24" height="24" style="display: block;" />
      <span>Foundry</span>
    </a>
    <div class="header-right">
      <SearchModal client:load />
      <SettingsModal client:load />
      <slot name="header-actions" />
    </div>
  </header>

  <div class="layout" id="layout">
    <Sidebar currentPath={currentPath} />

    <main class="content-area">
      <Breadcrumbs currentPath={currentPath} />

      <div class="sticky-heading-bar" id="sticky-heading-bar" aria-hidden="true"></div>

      <div class="content-row">
        <article class="content">
          <ContentStatusBanner client:load />
          <slot />
          <TtsSectionManager client:load />
          <PlayAllManager client:load />

        </article>
        <TableOfContents client:load />
      </div>
    </main>



    <AnnotationThread
      docPath={currentPath}
      client:load
    />
  </div>

  <TtsControlsBar client:load />
  <TokenModal client:load />
  <CommentDraft docPath={currentPath} client:load />

  <script is:inline>
    // Unified sidebar toggle (works on both desktop and mobile)
    const layout = document.getElementById('layout');
    const toggleBtn = document.getElementById('sidebar-toggle');
    const sidebar = document.querySelector('.sidebar');

    if (layout && toggleBtn) {
      // Restore state from localStorage (desktop only)
      if (window.innerWidth > 1024 && localStorage.getItem('foundry-sidebar') === 'hidden') {
        layout.classList.add('sidebar-hidden');
      }

      toggleBtn.addEventListener('click', () => {
        if (window.innerWidth <= 1024) {
          // Mobile/tablet: slide overlay
          if (sidebar) sidebar.classList.toggle('open');
        } else {
          // Desktop: collapse/expand
          layout.classList.toggle('sidebar-hidden');
          const isHidden = layout.classList.contains('sidebar-hidden');
          localStorage.setItem('foundry-sidebar', isHidden ? 'hidden' : 'visible');
        }
      });

      // Mobile/tablet: close sidebar when clicking outside (on the backdrop)
      document.addEventListener('click', function(e) {
        if (window.innerWidth <= 1024 && sidebar && sidebar.classList.contains('open')) {
          if (!sidebar.contains(e.target) && e.target !== toggleBtn && !toggleBtn.contains(e.target)) {
            sidebar.classList.remove('open');
          }
        }
      });
    }
  </script>

  {/* Scroll progress bar */}
  <script is:inline>
    (function() {
      const header = document.querySelector('.header');
      if (!header) return;
      function updateProgress() {
        const scrollTop = window.scrollY || document.documentElement.scrollTop;
        const docHeight = document.documentElement.scrollHeight - window.innerHeight;
        const progress = docHeight > 0 ? Math.min(scrollTop / docHeight, 1) : 0;
        header.style.setProperty('--scroll-progress', String(progress));
      }
      window.addEventListener('scroll', updateProgress, { passive: true });
      updateProgress();
    })();
  </script>

  {/* Cancel TTS on navigation */}
  <script is:inline>
    window.addEventListener("beforeunload", function() {
      if ("speechSynthesis" in window) speechSynthesis.cancel();
    });
  </script>

  {/* Mermaid — only loads when diagrams are present */}
  <script is:inline>
    (function() {
      if (!document.querySelector('pre.mermaid')) return;
      var s = document.createElement('script');
      s.src = 'https://cdn.jsdelivr.net/npm/mermaid@11/dist/mermaid.min.js';
      s.onload = function() {
        var isDark = document.documentElement.getAttribute('data-theme') === 'dark';
        mermaid.initialize({ startOnLoad: false, theme: isDark ? 'dark' : 'default' });
        mermaid.run({ querySelector: 'pre.mermaid' });
      };
      document.head.appendChild(s);
    })();
  </script>

  <script is:inline>
    (function() {
      var headings = document.querySelectorAll('.content h2, .content h3');
      if (!headings.length) return;
      var bar = document.getElementById('sticky-heading-bar');
      if (!bar) return;
      var headerHeight = parseInt(getComputedStyle(document.documentElement).getPropertyValue('--header-height')) || 48;
      var currentHeading = null;
      var displayedText = '';

      // Extract only direct text nodes from a heading (skips anchors and other elements)
      function getHeadingText(el) {
        var text = '';
        el.childNodes.forEach(function(node) {
          if (node.nodeType === 3) text += node.textContent;
        });
        return text.trim();
      }

      var observer = new IntersectionObserver(function(entries) {
        entries.forEach(function(entry) {
          if (!entry.isIntersecting) {
            currentHeading = entry.target;
          }
        });
        if (currentHeading) {
          var text = getHeadingText(currentHeading);
          var isH3 = currentHeading.tagName.toLowerCase() === 'h3';
          var levelClass = isH3 ? 'sticky-heading-h3' : 'sticky-heading-h2';

          bar.textContent = text;
          bar.className = 'sticky-heading-bar visible ' + levelClass;
          displayedText = text;
        }
      }, { rootMargin: '-' + headerHeight + 'px 0px 0px 0px', threshold: 0 });

      // Hide the bar when scrolled back to the top
      var resetObserver = new IntersectionObserver(function(entries) {
        entries.forEach(function(entry) {
          if (entry.isIntersecting && entry.boundingClientRect.top > headerHeight) {
            if (entry.target === headings[0]) {
              bar.className = 'sticky-heading-bar';
              currentHeading = null;
              displayedText = '';
            }
          }
        });
      }, { rootMargin: '0px 0px 0px 0px', threshold: 0 });

      headings.forEach(function(h) {
        observer.observe(h);
        resetObserver.observe(h);
      });
    })();
  </script>

  {/* Code copy buttons */}
  <script is:inline>
    (function() {
      document.querySelectorAll('pre > code').forEach(function(codeBlock) {
        var pre = codeBlock.parentElement;
        if (!pre || pre.classList.contains('mermaid')) return;
        pre.style.position = 'relative';
        var btn = document.createElement('button');
        btn.className = 'code-copy-btn';
        btn.setAttribute('aria-label', 'Copy code');
        btn.innerHTML = '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="9" y="9" width="13" height="13" rx="2" ry="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg>';
        btn.addEventListener('click', function() {
          var text = codeBlock.textContent || '';
          navigator.clipboard.writeText(text).then(function() {
            btn.innerHTML = '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>';
            btn.classList.add('code-copy-btn--copied');
            setTimeout(function() {
              btn.innerHTML = '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="9" y="9" width="13" height="13" rx="2" ry="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg>';
              btn.classList.remove('code-copy-btn--copied');
            }, 2000);
          });
        });
        pre.appendChild(btn);
      });
    })();
  </script>

  {/* Back to top button */}
  <script is:inline>
    (function() {
      var btn = document.createElement('button');
      btn.className = 'back-to-top';
      btn.setAttribute('aria-label', 'Scroll to top');
      btn.innerHTML = '<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="18 15 12 9 6 15"/></svg>';
      document.body.appendChild(btn);
      btn.addEventListener('click', function() {
        window.scrollTo({ top: 0, behavior: 'smooth' });
      });
      var visible = false;
      window.addEventListener('scroll', function() {
        var shouldShow = window.scrollY > 500;
        if (shouldShow !== visible) {
          visible = shouldShow;
          btn.classList.toggle('back-to-top--visible', visible);
        }
      }, { passive: true });
    })();
  </script>
</body>
</html>
